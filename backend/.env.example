# Google Gemini (aistudio.google.com — use a key from a billing-enabled
# project: the paid tier doesn't use prompts for model training).
# New AI Studio keys start with "AQ."; legacy "AIza" keys also work.
GEMINI_API_KEY=AQ.xxxx

# Shared secret for /api/cron/daily (reminder emails) — set the same value
# as the CRON_SECRET repository secret in GitHub Actions
CRON_SECRET=xxxx

# Supabase (Settings → API)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJ...    # service_role key (NOT anon)

# Email (Resend — get a key at resend.com, verify a sender domain)
RESEND_API_KEY=re_...
EMAIL_FROM=YOPEY Befriender <hello@yopey.org>

# Optional: CQC partner code (apply at cqc.org.uk if you want one)
CQC_PARTNER_CODE=YOPEY

# Dashboard
DASHBOARD_PASSWORD=changeme

# Safeguarding — INTERNAL escalation inbox. Where alert emails go when the bot
# detects a concern (about the young person OR about a care home). Set to the
# named safeguarding lead. If unset, alerts fall back to the EMAIL_FROM inbox
# (still recorded on the dashboard either way). NOT shown to young people.
SAFEGUARDING_EMAIL=safeguarding@yopey.org

# Safeguarding — TEEN-FACING contact. The real person the bot tells a young
# person to talk to when something concerning comes up. Human-readable string.
YOPEY_SAFEGUARDING_CONTACT=YOPEY's safeguarding lead — hello@yopey.org or 01440 821654

# Secret used to sign yes/no email response links. Anything random + long.
EMAIL_TOKEN_SECRET=change-me-to-something-random-and-long

# Public URL of THIS backend — used in email links so teens can click them.
# Dev: http://localhost:8000
# Prod: https://api.yopeybefriender.org
APP_BASE_URL=http://localhost:8000

# Public URL of the FRONTEND — used to build magic-link "return" URLs in emails.
# Dev: http://localhost:3000 · Prod: https://yopey-befriender.vercel.app
FRONTEND_BASE_URL=https://yopey-befriender.vercel.app

# CORS — comma-separated list of allowed frontend origins
# In dev: http://localhost:3000
# In prod: https://befriender.yopey.org
ALLOWED_ORIGINS=http://localhost:3000

# Server
PORT=8000

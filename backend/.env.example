# OpenAI
OPENAI_API_KEY=sk-...

# Supabase (Settings → API)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJ...    # service_role key (NOT anon)

# Email (Resend — get a key at resend.com, verify a sender domain)
RESEND_API_KEY=re_...
EMAIL_FROM=YOPEY Befriender <hello@yopey.org>

# Optional: CQC partner code (apply at cqc.org.uk if you want one)
CQC_PARTNER_CODE=YOPEY

# Dashboard
DASHBOARD_PASSWORD=changeme

# Secret used to sign yes/no email response links. Anything random + long.
EMAIL_TOKEN_SECRET=change-me-to-something-random-and-long

# Public URL of THIS backend — used in email links so teens can click them.
# Dev: http://localhost:8000
# Prod: https://api.yopeybefriender.org
APP_BASE_URL=http://localhost:8000

# CORS — comma-separated list of allowed frontend origins
# In dev: http://localhost:3000
# In prod: https://befriender.yopey.org
ALLOWED_ORIGINS=http://localhost:3000

# Server
PORT=8000
